<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClothingStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClothingStore.styles.css" asp-append-version="true" />
    <!-- Font Awesome 6 -->
 
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
          
         .card {
             background: #ffffff;  
             border-radius: 1.25rem;
             box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05), 0 1px 2px rgba(0, 0, 0, 0.03);
             transition: box-shadow 0.2s ease;
             border: 1px solid rgba(226, 232, 240, 0.6);
         }

         .card:hover {
             box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
         }

         /* ---------- gradient text (classic blue) ---------- */
         .gradient-text {
             background: linear-gradient(135deg, #1e3a5f, #2563eb);
             -webkit-background-clip: text;
             -webkit-text-fill-color: transparent;
             background-clip: text;
         }

         /* ---------- badge (clean) ---------- */
         .badge-live {
             background: #dcfce7;
             color: #166534;
             font-weight: 600;
             padding: 0.2rem 0.9rem;
             border-radius: 9999px;
             font-size: 0.65rem;
             letter-spacing: 0.3px;
             border: 1px solid #bbf7d0;
         }

         /* ---------- avatar ring (subtle) ---------- */
         .avatar-ring {
             border: 2px solid #e2e8f0;
             transition: border-color 0.2s;
         }

         .avatar-ring:hover {
             border-color: #2563eb;
         }

         /* ---------- custom range slider ---------- */
         input[type="range"] {
             -webkit-appearance: none;
             appearance: none;
             background: #e2e8f0;
             height: 4px;
             border-radius: 999px;
         }

         input[type="range"]::-webkit-slider-thumb {
             -webkit-appearance: none;
             appearance: none;
             width: 16px;
             height: 16px;
             border-radius: 50%;
             background: #2563eb;
             cursor: pointer;
             border: 2px solid white;
             box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
             transition: 0.15s;
         }

         input[type="range"]::-webkit-slider-thumb:hover {
             transform: scale(1.1);
         }

         /* ---------- checkbox & radio (clean) ---------- */
         .fancy-check:checked {
             background-color: #2563eb;
             border-color: #2563eb;
         }

         .fancy-radio:checked {
             border-color: #2563eb;
             background-color: #2563eb;
         }

         /* ---------- toggle switch (clean) ---------- */
         .toggle-switch {
             width: 40px;
             height: 22px;
             background-color: #cbd5e1;
             border-radius: 999px;
             position: relative;
             cursor: pointer;
             transition: background-color 0.2s;
             flex-shrink: 0;
             border: 1px solid #e2e8f0;
         }

         .toggle-switch::after {
             content: '';
             position: absolute;
             top: 2px;
             left: 2px;
             width: 16px;
             height: 16px;
             background: white;
             border-radius: 50%;
             transition: transform 0.2s;
             box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
         }

         .toggle-input:checked+.toggle-switch {
             background-color: #2563eb;
             border-color: #2563eb;
         }

         .toggle-input:checked+.toggle-switch::after {
             transform: translateX(18px);
         }

         /* ---------- stat cards (clean) ---------- */
         .stat-icon {
             background: #eff6ff;
             color: #2563eb;
             border-radius: 1rem;
             width: 3rem;
             height: 3rem;
             display: flex;
             align-items: center;
             justify-content: center;
             font-size: 1.25rem;
         }

         /* ---------- TABLE HEADER – classic professional ---------- */
         .table-header-classic {
             background: #f8fafc;
             border-bottom: 2px solid #e2e8f0;
         }

         .table-header-classic th {
             padding: 0.9rem 1.25rem;
             font-weight: 700;
             font-size: 0.7rem;
             text-transform: uppercase;
             letter-spacing: 0.5px;
             color: #475569;
             text-align: left;
         }

         /* ---------- table row hover (subtle) ---------- */
         .table-row-classic:hover {
             background: #f8fafc;
             transition: background 0.15s;
         }

         /* ---------- status badges (clean) ---------- */
         .status-badge {
             padding: 0.2rem 0.9rem;
             border-radius: 9999px;
             font-weight: 600;
             font-size: 0.7rem;
             letter-spacing: 0.2px;
             display: inline-block;
         }

         .status-completed {
             background: #dcfce7;
             color: #166534;
         }

         .status-pending {
             background: #fef9c3;
             color: #854d0e;
         }

         .status-refunded {
             background: #fee2e2;
             color: #991b1b;
         }

         /* ---------- form inputs (clean) ---------- */
         .form-input {
             border: 1px solid #e2e8f0;
             border-radius: 0.75rem;
             padding: 0.6rem 1rem;
             background: #fafbfc;
             transition: border-color 0.2s, box-shadow 0.2s;
             width: 100%;
             font-size: 0.9rem;
         }

         .form-input:focus {
             border-color: #2563eb;
             box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08);
             outline: none;
             background: #ffffff;
         }

         /* ---------- button (classic) ---------- */
         .btn-primary {
             background: #2563eb;
             color: white;
             font-weight: 600;
             padding: 0.6rem 1.5rem;
             border-radius: 0.75rem;
             transition: background 0.2s, box-shadow 0.2s;
             border: none;
             cursor: pointer;
             font-size: 0.9rem;
         }

         .btn-primary:hover {
             background: #1d4ed8;
             box-shadow: 0 4px 16px rgba(37, 99, 235, 0.2);
         }

         .btn-secondary {
             background: #f1f5f9;
             color: #334155;
             font-weight: 600;
             padding: 0.6rem 1.5rem;
             border-radius: 0.75rem;
             transition: background 0.2s;
             border: 1px solid #e2e8f0;
             cursor: pointer;
             font-size: 0.9rem;
         }

         .btn-secondary:hover {
             background: #e2e8f0;
         }

         .btn-danger {
             background: #fee2e2;
             color: #991b1b;
             font-weight: 600;
             padding: 0.6rem 1.5rem;
             border-radius: 0.75rem;
             transition: background 0.2s;
             border: none;
             cursor: pointer;
             font-size: 0.9rem;
         }

         .btn-danger:hover {
             background: #fecaca;
         }

         /* ---------- any component can be placed anywhere ---------- */
         .component-wrapper {
             transition: all 0.2s;
         }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">ClothingStore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            
                            <a class="nav-link text-dark" asp-area="" asp-controller="Category" asp-action="Index">Category</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ClothingStore - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
